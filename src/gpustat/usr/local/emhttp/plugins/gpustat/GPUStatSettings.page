// Build DISP+UPPER keys from GPU data — $settings whitelist controls what shows
function processGPUPoolData($gpustat_pool) {
    $newData = array();
    foreach ($gpustat_pool as $pciId => $gpuData) {
        $processedData = array();
        foreach ($gpuData as $key => $value) {
            if ($value === 'N/A' || $value === null || is_array($value)) continue;
            $processedData['DISP' . strtoupper($key)] = $value;
        }
        $newData[$pciId] = $processedData;
    }
    return $newData;
}

if (isset($gpustat_data)) {
    // Build settings needed for each GPU
    $processedGPUPoolData = processGPUPoolData($gpustat_pool);

    foreach ($gpustat_data as $gpufresh) {
        $gpumodel_fresh = $gpufresh['model'];
        $gpuid_fresh = $gpufresh['id'];
        $gpudesc = sprintf(
            '%s: %s%s%s',
